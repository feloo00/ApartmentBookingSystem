@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<style>
    body {
        background: linear-gradient(180deg, #fffaf3 0%, #f7fbff 55%, #ffffff 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .about-page {
        padding: 42px 0 80px;
    }

    .about-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 90px 50px;
        margin-bottom: 38px;
        color: white;
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.80), rgba(41, 182, 246, 0.72)), url('/images/about/hero.jpg');
        background-size: cover;
        background-position: center;
        box-shadow: 0 28px 65px rgba(0,0,0,0.16);
        isolation: isolate;
    }

        .about-hero::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            top: -100px;
            right: -80px;
            background: rgba(255,255,255,0.10);
            filter: blur(5px);
            z-index: 0;
        }

        .about-hero::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            bottom: -70px;
            left: -50px;
            background: rgba(255,255,255,0.08);
            z-index: 0;
        }

    .about-hero-content {
        position: relative;
        z-index: 2;
        max-width: 820px;
    }

    .about-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(255,255,255,0.16);
        border: 1px solid rgba(255,255,255,0.20);
        backdrop-filter: blur(10px);
        font-size: 0.86rem;
        font-weight: 800;
        margin-bottom: 18px;
        letter-spacing: 0.3px;
    }

    .about-title {
        font-size: 3.2rem;
        font-weight: 900;
        line-height: 1.12;
        margin-bottom: 16px;
    }

    .about-subtitle {
        font-size: 1.08rem;
        line-height: 1.95;
        opacity: 0.96;
        max-width: 760px;
        margin-bottom: 0;
    }

    .luxury-stats {
        margin-top: -10px;
        margin-bottom: 34px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
    }

    .luxury-stat-card {
        background: rgba(255,255,255,0.82);
        border: 1px solid rgba(255,255,255,0.92);
        border-radius: 24px;
        padding: 24px 20px;
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.06);
        text-align: center;
        backdrop-filter: blur(10px);
    }

    .luxury-stat-number {
        font-size: 2rem;
        font-weight: 900;
        color: #0f766e;
        margin-bottom: 8px;
        line-height: 1;
    }

    .luxury-stat-label {
        color: #4b5563;
        font-size: 0.95rem;
        font-weight: 700;
        line-height: 1.6;
    }

    .about-section {
        margin-top: 48px;
    }

    .section-heading {
        text-align: center;
        max-width: 860px;
        margin: 0 auto 28px;
    }

    .section-title {
        font-size: 2.05rem;
        font-weight: 900;
        color: #111827;
        margin-bottom: 12px;
        line-height: 1.3;
    }

    .section-text {
        color: #6b7280;
        line-height: 1.95;
        font-size: 1rem;
    }

    .story-card {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        background: linear-gradient(135deg, rgba(41, 182, 246, 0.10), rgba(38, 198, 218, 0.08), rgba(255, 248, 239, 0.90));
        border: 1px solid rgba(255,255,255,0.92);
        box-shadow: 0 18px 50px rgba(15, 23, 42, 0.06);
        backdrop-filter: blur(12px);
    }

    .story-inner {
        display: grid;
        grid-template-columns: 390px 1fr;
        gap: 24px;
        align-items: center;
        padding: 18px;
    }

    .story-image-wrap {
        position: relative;
        overflow: hidden;
        width: 100%;
        height: 280px;
        min-height: 280px;
        border-radius: 24px;
        box-shadow: 0 12px 28px rgba(0,0,0,0.10);
    }

        .story-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .story-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0,0,0,0.04), rgba(0,0,0,0.14));
    }

    .story-content {
        padding: 8px 8px 8px 2px;
    }

    .story-chip {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.72);
        color: #0f766e;
        font-size: 0.84rem;
        font-weight: 800;
        margin-bottom: 14px;
        border: 1px solid rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
    }

    .story-title {
        font-size: 1.7rem;
        font-weight: 900;
        color: #111827;
        margin-bottom: 8px;
        line-height: 1.35;
    }

    .story-divider {
        width: 58px;
        height: 4px;
        border-radius: 999px;
        background: linear-gradient(90deg, #0f766e, #29b6f6);
        margin: 12px 0 18px;
    }

    .story-text {
        color: #4b5563;
        line-height: 1.95;
        font-size: 0.98rem;
        margin-bottom: 0;
    }

    .categories-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
        margin-top: 26px;
    }

    .category-card {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        background: linear-gradient(135deg, rgba(255,255,255,0.88), rgba(247,251,255,0.95), rgba(255,248,239,0.95));
        border: 1px solid rgba(255,255,255,0.92);
        box-shadow: 0 18px 48px rgba(15, 23, 42, 0.06);
        padding: 26px;
        backdrop-filter: blur(10px);
    }

    .category-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.72);
        color: #0f766e;
        font-size: 0.84rem;
        font-weight: 800;
        margin-bottom: 14px;
        border: 1px solid rgba(255,255,255,0.88);
        backdrop-filter: blur(8px);
    }

    .category-title {
        font-size: 1.45rem;
        font-weight: 900;
        color: #111827;
        margin-bottom: 10px;
        line-height: 1.35;
    }

    .category-text {
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 18px;
        font-size: 0.97rem;
    }

    .category-points {
        display: grid;
        gap: 12px;
    }

    .category-point {
        display: flex;
        align-items: center;
        gap: 10px;
        min-height: 54px;
        padding: 12px 14px;
        border-radius: 16px;
        color: #374151;
        font-size: 0.93rem;
        font-weight: 700;
        background: rgba(255,255,255,0.72);
        border: 1px solid rgba(255,255,255,0.88);
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.03);
        backdrop-filter: blur(8px);
    }

    .point-check {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #dcfce7;
        color: #166534;
        font-size: 0.86rem;
        font-weight: 900;
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .why-card {
        background: linear-gradient(135deg, rgba(255,255,255,0.88), rgba(247,251,255,0.96));
        border-radius: 24px;
        padding: 24px 20px;
        box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
        border: 1px solid rgba(255,255,255,0.92);
        backdrop-filter: blur(10px);
    }

    .why-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
        font-size: 1.4rem;
        background: linear-gradient(135deg, #29b6f6, #26c6da);
        color: white;
        box-shadow: 0 10px 24px rgba(41,182,246,0.18);
    }

    .why-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #111827;
        margin-bottom: 8px;
    }

    .why-text {
        color: #6b7280;
        line-height: 1.8;
        font-size: 0.95rem;
    }

    .luxury-cta {
        margin-top: 56px;
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 50px 30px;
        text-align: center;
        color: #0f172a;
        background: linear-gradient(135deg, rgba(41, 182, 246, 0.18) 0%, rgba(38, 198, 218, 0.14) 48%, rgba(255, 248, 239, 0.98) 100%);
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
        border: 1px solid rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
    }

        .luxury-cta::before {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(41, 182, 246, 0.12);
            top: -60px;
            right: -50px;
            filter: blur(8px);
        }

        .luxury-cta::after {
            content: "";
            position: absolute;
            width: 170px;
            height: 170px;
            border-radius: 50%;
            background: rgba(255, 183, 77, 0.10);
            bottom: -50px;
            left: -40px;
            filter: blur(8px);
        }

    .luxury-cta-content {
        position: relative;
        z-index: 2;
        max-width: 760px;
        margin: 0 auto;
    }

    .luxury-cta-title {
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 12px;
        color: #111827;
    }

    .luxury-cta-text {
        line-height: 1.9;
        color: #4b5563;
        margin-bottom: 22px;
    }

    .luxury-cta-btn {
        display: inline-block;
        padding: 14px 24px;
        border-radius: 999px;
        background: linear-gradient(135deg, #0f766e, #29b6f6);
        color: white;
        font-weight: 900;
        text-decoration: none;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 12px 24px rgba(41,182,246,0.20);
    }

        .luxury-cta-btn:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 16px 30px rgba(41,182,246,0.26);
        }

    .fade-up {
        opacity: 0;
        transform: translateY(24px);
        animation: fadeUp 0.8s ease forwards;
    }

    .delay-1 {
        animation-delay: 0.04s;
    }

    .delay-2 {
        animation-delay: 0.08s;
    }

    .delay-3 {
        animation-delay: 0.12s;
    }

    .delay-4 {
        animation-delay: 0.16s;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .luxury-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .why-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .story-inner {
            grid-template-columns: 320px 1fr;
        }

        .story-image-wrap {
            height: 240px;
            min-height: 240px;
        }
    }

    @@media (max-width: 991px) {
        .about-hero {
            padding: 64px 32px;
        }

        .about-title {
            font-size: 2.5rem;
        }

        .story-inner {
            grid-template-columns: 1fr;
        }

        .story-image-wrap {
            height: 240px;
            min-height: 240px;
        }

        .categories-grid,
        .why-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .about-page {
            padding: 26px 0 60px;
        }

        .about-hero {
            border-radius: 26px;
            padding: 48px 22px;
            margin-bottom: 28px;
        }

        .about-title {
            font-size: 2rem;
        }

        .about-subtitle {
            font-size: 0.98rem;
            line-height: 1.85;
        }

        .section-title {
            font-size: 1.7rem;
        }

        .luxury-stats {
            grid-template-columns: 1fr;
        }

        .story-inner {
            padding: 14px;
        }

        .story-title,
        .category-title {
            font-size: 1.28rem;
        }

        .story-image-wrap {
            height: 210px;
            min-height: 210px;
            border-radius: 20px;
        }

        .luxury-cta-title {
            font-size: 1.55rem;
        }
    }
</style>

<div class="container about-page">

    <div class="about-hero fade-up">
        <div class="about-hero-content">
            <div class="about-badge">@Localizer["AboutBadge"]</div>
            <h1 class="about-title">@Localizer["AboutTitle"]</h1>
            <p class="about-subtitle">@Localizer["AboutSubtitle"]</p>
        </div>
    </div>

    <div class="luxury-stats fade-up delay-1">
        <div class="luxury-stat-card">
            <div class="luxury-stat-number">@Localizer["Stat1Number"]</div>
            <div class="luxury-stat-label">@Localizer["Stat1Label"]</div>
        </div>
        <div class="luxury-stat-card">
            <div class="luxury-stat-number">@Localizer["Stat2Number"]</div>
            <div class="luxury-stat-label">@Localizer["Stat2Label"]</div>
        </div>
        <div class="luxury-stat-card">
            <div class="luxury-stat-number">@Localizer["Stat3Number"]</div>
            <div class="luxury-stat-label">@Localizer["Stat3Label"]</div>
        </div>
        <div class="luxury-stat-card">
            <div class="luxury-stat-number">@Localizer["Stat4Number"]</div>
            <div class="luxury-stat-label">@Localizer["Stat4Label"]</div>
        </div>
    </div>

    <div class="about-section fade-up delay-1">
        <div class="section-heading">
            <div class="section-title">@Localizer["WhoWeAreTitle"]</div>
            <div class="section-text">@Localizer["WhoWeAreText"]</div>
        </div>

        <div class="story-card">
            <div class="story-inner">
                <div class="story-image-wrap">
                    <img src="/images/about/about-main.jpg" alt="Luxury apartment in Alexandria" />
                    <div class="story-image-overlay"></div>
                </div>

                <div class="story-content">
                    <div class="story-chip">@Localizer["StoryChip"]</div>
                    <div class="story-title">@Localizer["StoryTitle"]</div>
                    <div class="story-divider"></div>
                    <div class="story-text">@Localizer["StoryText"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="about-section fade-up delay-2">
        <div class="section-heading">
            <div class="section-title">@Localizer["CollectionTitle"]</div>
            <div class="section-text">@Localizer["CollectionText"]</div>
        </div>

        <div class="categories-grid">
            <div class="category-card">
                <div class="category-badge">@Localizer["Category1Badge"]</div>
                <div class="category-title">@Localizer["Category1Title"]</div>
                <div class="category-text">@Localizer["Category1Text"]</div>
                <div class="category-points">
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category1Point1"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category1Point2"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category1Point3"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category1Point4"]</div>
                </div>
            </div>

            <div class="category-card">
                <div class="category-badge">@Localizer["Category2Badge"]</div>
                <div class="category-title">@Localizer["Category2Title"]</div>
                <div class="category-text">@Localizer["Category2Text"]</div>
                <div class="category-points">
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category2Point1"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category2Point2"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category2Point3"]</div>
                    <div class="category-point"><span class="point-check">✓</span>@Localizer["Category2Point4"]</div>
                </div>
            </div>
        </div>
    </div>

    <div class="about-section fade-up delay-3">
        <div class="section-heading">
            <div class="section-title">@Localizer["WhyChooseTitle"]</div>
            <div class="section-text">@Localizer["WhyChooseText"]</div>
        </div>

        <div class="why-grid">
            <div class="why-card">
                <div class="why-icon">🏠</div>
                <div class="why-title">@Localizer["Why1Title"]</div>
                <div class="why-text">@Localizer["Why1Text"]</div>
            </div>

            <div class="why-card">
                <div class="why-icon">🌊</div>
                <div class="why-title">@Localizer["Why2Title"]</div>
                <div class="why-text">@Localizer["Why2Text"]</div>
            </div>

            <div class="why-card">
                <div class="why-icon">🛋️</div>
                <div class="why-title">@Localizer["Why3Title"]</div>
                <div class="why-text">@Localizer["Why3Text"]</div>
            </div>

            <div class="why-card">
                <div class="why-icon">⭐</div>
                <div class="why-title">@Localizer["Why4Title"]</div>
                <div class="why-text">@Localizer["Why4Text"]</div>
            </div>
        </div>
    </div>

    <div class="luxury-cta fade-up delay-4">
        <div class="luxury-cta-content">
            <div class="luxury-cta-title">@Localizer["CtaTitle"]</div>
            <div class="luxury-cta-text">@Localizer["CtaText"]</div>
            <a href="#global-contact-section" class="luxury-cta-btn">@Localizer["CtaButton"]</a>
        </div>
    </div>

</div>