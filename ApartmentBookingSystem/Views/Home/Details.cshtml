                        </div>
                    </div>

                    <div class="policy-card">
                        <div class="policy-title">
                            <div class="policy-icon">🔇</div>
                            <span>@Localizer["NoisePolicy"]</span>
                        </div>
                        <div class="policy-text">
                            @Localizer["NoisePolicyText"]
                        </div>
                    </div>

                    <div class="policy-card">
                        <div class="policy-title">
                            <div class="policy-icon">💍</div>
                            <span>@Localizer["CouplesReservations"]</span>
                        </div>
                        <div class="policy-text">
                            @Localizer["CouplesReservationsText"]
                        </div>
                    </div>

                    <div class="policy-card">
                        <div class="policy-title">
                            <div class="policy-icon">🧑‍🤝‍🧑</div>
