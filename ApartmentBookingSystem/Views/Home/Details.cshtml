                <div class="alert premium-alert mt-4 text-center">

                    <p class="mb-4 premium-text">
                        @Localizer["PleaseSignInToReview"]
                    </p>

                    <div class="premium-buttons">

                        <a asp-area="Identity" asp-page="/Account/Login" class="btn-premium btn-login">
                             @Localizer["SignIn"]
                        </a>

                        <a asp-area="Identity" asp-page="/Account/Register" class="btn-premium btn-register">
                             @Localizer["Register"]
                        </a>

                    </div>
