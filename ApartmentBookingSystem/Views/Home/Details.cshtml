                    </div>

                    <div class="policy-card">
                        <div class="policy-title">
                            <div class="policy-icon">💳</div>
                            <span>@Localizer["CancellationPolicy"]</span>
                        </div>
                        <div class="policy-text">
                            @Localizer["CancellationPolicyText"]
                        </div>
                    </div>

                    <div class="policy-card">
                        <div class="policy-title">
                            <div class="policy-icon">👥</div>
                            <span>@Localizer["GuestPolicy"]</span>
                        </div>
                        <div class="policy-text">
                            @Localizer["GuestPolicyText"]
                        </div>
                    </div>

                    <div class="policy-card">
