                        <label for="star3" title="@Localizer["ThreeStars"]">★</label>

                        <input type="radio" id="star2" name="rating" value="2" />
                        <label for="star2" title="@Localizer["TwoStars"]">★</label>

                        <input type="radio" id="star1" name="rating" value="1" />
                        <label for="star1" title="@Localizer["OneStar"]">★</label>
