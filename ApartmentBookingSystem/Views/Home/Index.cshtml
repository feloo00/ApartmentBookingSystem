@model IEnumerable<ApartmentBookingSystem.Models.Apartment>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["HomeTitle"];
}

<style>
    body {
        background: linear-gradient(180deg, #fffaf3 0%, #f7fcff 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .hero-section {
        background: linear-gradient(135deg, rgba(255, 183, 77, 0.92), rgba(79, 195, 247, 0.88)), url('https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1400&q=80');
        background-size: cover;
        background-position: center;
        border-radius: 28px;
        padding: 80px 40px;
        color: white;
        margin-bottom: 50px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        position: relative;
        overflow: hidden;
    }

        .hero-section::after {
            content: "";
            position: absolute;
            width: 250px;
            height: 250px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            top: -60px;
            right: -60px;
        }

        .hero-section::before {
            content: "";
            position: absolute;
            width: 180px;
            height: 180px;
            background: rgba(255,255,255,0.12);
            border-radius: 50%;
            bottom: -50px;
            left: -40px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 700px;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 15px;
        line-height: 1.2;
    }

    .hero-text {
        font-size: 1.1rem;
        opacity: 0.95;
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 10px;
    }

    .section-subtitle {
        color: #6b7280;
        margin-bottom: 30px;
    }

    .apartment-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        transition: all 0.35s ease;
        height: 100%;
        position: relative;
    }

        .apartment-card:hover {
            transform: translateY(-10px) scale(1.01);
            box-shadow: 0 20px 40px rgba(0,0,0,0.14);
        }

    .image-wrapper {
        position: relative;
        overflow: hidden;
    }

    .apartment-img {
        height: 240px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .apartment-card:hover .apartment-img {
        transform: scale(1.08);
    }

    .price-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: linear-gradient(135deg, #ff8a65, #ffb74d);
        color: white;
        padding: 10px 16px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 700;
        box-shadow: 0 8px 20px rgba(255, 138, 101, 0.35);
    }

    .card-body-custom {
        padding: 22px;
    }

    .apartment-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 10px;
    }

    .location-text {
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 18px;
    }

    .card-footer-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
    }

    .summer-btn {
        background: linear-gradient(135deg, #29b6f6, #26c6da);
        border: none;
        color: white;
        font-weight: 700;
        border-radius: 14px;
        padding: 12px 18px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        width: 100%;
        text-align: center;
        box-shadow: 0 10px 20px rgba(41, 182, 246, 0.25);
    }

        .summer-btn:hover {
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 14px 24px rgba(41, 182, 246, 0.35);
        }

    .mini-tag {
        display: inline-block;
        background: #fef3c7;
        color: #b45309;
        font-size: 0.8rem;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 999px;
        margin-bottom: 12px;
    }

    .empty-image {
        height: 240px;
        background: linear-gradient(135deg, #dbeafe, #fde68a);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #374151;
        font-size: 1rem;
        font-weight: 700;
    }

    .fade-up {
        animation: fadeUp 0.8s ease forwards;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .hero-section {
            padding: 50px 25px;
        }

        .hero-title {
            font-size: 2.1rem;
        }
    }

    .image-scroll {
        display: flex;
        overflow-x: auto;
        gap: 10px;
        padding: 10px;
        scroll-snap-type: x mandatory;
    }

        .image-scroll::-webkit-scrollbar {
            display: none;
        }

    .scroll-img {
        flex: 0 0 auto;
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-radius: 12px;
        scroll-snap-align: start;
        transition: transform .3s;
    }

        .scroll-img:hover {
            transform: scale(1.05);
        }

    .custom-slider {
        position: relative;
        overflow: hidden;
        width: 100%;
        height: 240px;
        border-radius: 20px 20px 0 0;
    }

    .slider-track {
        display: flex;
        height: 100%;
        transition: transform 0.6s ease-in-out;
    }

    .slider-slide {
        min-width: 100%;
        height: 240px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .slider-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .slider-slide:hover .slider-image {
        transform: scale(1.08);
    }

    .slider-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 5;
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.85);
        color: #333;
        font-size: 20px;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        transition: all 0.3s ease;
    }

        .slider-btn:hover {
            background: white;
            transform: translateY(-50%) scale(1.08);
        }

    .prev-btn {
        left: 12px;
    }

    .next-btn {
        right: 12px;
    }

    .slider-dots {
        position: absolute;
        bottom: 14px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
        z-index: 5;
        background: rgba(0,0,0,0.15);
        padding: 6px 10px;
        border-radius: 999px;
        backdrop-filter: blur(6px);
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.6);
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .dot.active {
            background: white;
            transform: scale(1.2);
        }

    .custom-slider,
    .slider-track {
        direction: ltr;
    }

    .video-slide {
        position: relative;
    }

        .video-slide .slider-image {
            filter: brightness(0.88);
        }

    .video-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.12);
    }

    .video-play-btn {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        background: rgba(255,255,255,0.92);
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        box-shadow: 0 10px 24px rgba(0,0,0,0.18);
    }

    .video-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(17, 24, 39, 0.82);
        color: white;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        z-index: 6;
    }

    .thumb-video {
        position: relative;
    }

    .thumb-video-icon {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
        background: rgba(0,0,0,0.20);
    }

    .video-click {
        cursor: pointer;
    }

    .apartment-features {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        margin-bottom: 18px;
        margin-top: 8px;
    }

    .feature-item {
        background: #f9fafb;
        border-radius: 12px;
        padding: 10px 12px;
        font-size: 0.92rem;
        color: #374151;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        line-height: 1.4;
    }

    .feature-icon {
        font-size: 1rem;
        flex-shrink: 0;
    }
s

</style>

<div class="container py-4">

    <div class="hero-section fade-up">
        <div class="hero-content">
            <span class="mini-tag">@Localizer["HeroTag"]</span>
            <h1 class="hero-title">@Localizer["HeroTitle"]</h1>
            <p class="hero-text">
                @Localizer["HeroText"]
            </p>
            <a href="#apartments" class="summer-btn" style="max-width:220px;">
                @Localizer["ExploreApartments"]
            </a>
        </div>
    </div>

    <div id="apartments" class="mb-4 fade-up">
        <h2 class="section-title">@Localizer["AvailableApartments"]</h2>
        <p class="section-subtitle">@Localizer["AvailableApartmentsSubtitle"]</p>
    </div>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 fade-up">
                <div class="apartment-card">

                    <div class="image-wrapper">
                        @{
                            var hasImages = item.Images != null && item.Images.Any();
                            var hasVideo = !string.IsNullOrWhiteSpace(item.VideoUrl);

                            string? videoThumbnail = null;

                            if (hasVideo)
                            {
                                string videoId = "";

                                if (item.VideoUrl.Contains("watch?v="))
                                {
                                    videoId = item.VideoUrl.Split("watch?v=").Last().Split('&').First();
                                }
                                else if (item.VideoUrl.Contains("youtu.be/"))
                                {
                                    var cleanUrl = item.VideoUrl.Split('?')[0];
                                    videoId = cleanUrl.Split('/').Last();
                                }
                                else if (item.VideoUrl.Contains("/embed/"))
                                {
                                    videoId = item.VideoUrl.Split("/embed/").Last().Split('?').First();
                                }

                                if (!string.IsNullOrEmpty(videoId))
                                {
                                    videoThumbnail = $"https://img.youtube.com/vi/{videoId}/hqdefault.jpg";
                                }
                            }

                            var mediaCount = (hasImages ? item.Images.Count() : 0) + (hasVideo && !string.IsNullOrWhiteSpace(videoThumbnail) ? 1 : 0);
                        }

                        @if (hasImages || hasVideo)
                        {
                            var apartmentId = $"slider-{item.Id}";
                            var dotsId = $"dots-{item.Id}";
                            var prevBtnId = $"prev-{item.Id}";
                            var nextBtnId = $"next-{item.Id}";

                            <div class="custom-slider" id="@apartmentId">
                                <button type="button" class="slider-btn prev-btn" id="@prevBtnId">&#10094;</button>
                                <button type="button" class="slider-btn next-btn" id="@nextBtnId">&#10095;</button>

                                <div class="slider-track">
                                    @if (hasImages)
                                    {
                                        @foreach (var img in item.Images)
                                        {
                                            <div class="slider-slide">
                                                <img src="@img.ImageUrl" class="slider-image" alt="@item.Title" />
                                            </div>
                                        }
                                    }

                                    @if (hasVideo && !string.IsNullOrWhiteSpace(videoThumbnail))
                                    {
                                        <div class="slider-slide video-slide video-click"
                                             data-url="@Url.Action("Details", "Home", new { id = item.Id })">
                                            <span class="video-badge">Video Tour</span>
                                            <img src="@videoThumbnail" class="slider-image" alt="@item.Title Video" />
                                            <div class="video-overlay">
                                                <div class="video-play-btn">▶</div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="slider-dots" id="@dotsId">
                                    @for (int i = 0; i < mediaCount; i++)
                                    {
                                        <span class="dot @(i == 0 ? "active" : "")" data-index="@i"></span>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="empty-image">
                                @Localizer["NoImageAvailable"]
                            </div>
                        }

                        <div class="price-badge">
                            @item.PricePerNight @Localizer["EGPPerNight"]
                        </div>
                    </div>

                    <div class="card-body-custom">

                        <div class="mini-tag">@Localizer["BestChoice"]</div>

                        <h5 class="apartment-title">@item.Title</h5>

                        <p class="location-text">
                            📍 @item.City - @item.Area
                        </p>

                        <div class="apartment-features">

                            <div class="feature-item">
                                <span class="feature-icon">📐</span>
                                <span>@item.ApartmentSize m² </span>
                            </div>

                            <div class="feature-item">
                                <span class="feature-icon">🛏</span>
                                <span>@item.Rooms @Localizer["Bedrooms"]</span>
                            </div>

                            <div class="feature-item">
                                <span class="feature-icon">🚿</span>
                                <span>@item.Bathrooms @Localizer["Bathrooms"]</span>
                            </div>

                            <div class="feature-item">
                                <span class="feature-icon">👥</span>
                                <span>@item.MaxGuests @Localizer["Guests"]</span>
                            </div>

                        </div>


                        <div class="card-footer-custom">
                            <a asp-controller="Home"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="summer-btn">
                                @Localizer["ViewDetails"]
                            </a>
                        </div>

                    </div>


                </div>
            </div>
        }
    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const sliders = document.querySelectorAll(".custom-slider");

            sliders.forEach(slider => {
                const track = slider.querySelector(".slider-track");
                const slides = slider.querySelectorAll(".slider-slide");
                const dots = slider.querySelectorAll(".dot");
                const prevBtn = slider.querySelector(".prev-btn");
                const nextBtn = slider.querySelector(".next-btn");

                let currentIndex = 0;
                let autoSlide;

                function updateSlider(index) {
                    track.style.transform = `translateX(-${index * 100}%)`;

                    dots.forEach(dot => dot.classList.remove("active"));
                    if (dots[index]) {
                        dots[index].classList.add("active");
                    }

                    currentIndex = index;
                }

                function nextSlide() {
                    let newIndex = currentIndex + 1;
                    if (newIndex >= slides.length) {
                        newIndex = 0;
                    }
                    updateSlider(newIndex);
                }

                function prevSlide() {
                    let newIndex = currentIndex - 1;
                    if (newIndex < 0) {
                        newIndex = slides.length - 1;
                    }
                    updateSlider(newIndex);
                }

                function startAutoSlide() {
                    autoSlide = setInterval(() => {
                        nextSlide();
                    }, 3000);
                }

                function stopAutoSlide() {
                    clearInterval(autoSlide);
                }

                nextBtn.addEventListener("click", function () {
                    nextSlide();
                    stopAutoSlide();
                    startAutoSlide();
                });

                prevBtn.addEventListener("click", function () {
                    prevSlide();
                    stopAutoSlide();
                    startAutoSlide();
                });

                dots.forEach(dot => {
                    dot.addEventListener("click", function () {
                        const index = parseInt(this.getAttribute("data-index"));
                        updateSlider(index);
                        stopAutoSlide();
                        startAutoSlide();
                    });
                });

                slider.addEventListener("mouseenter", stopAutoSlide);
                slider.addEventListener("mouseleave", startAutoSlide);

                updateSlider(0);
                startAutoSlide();
            });
        });

                document.querySelectorAll(".video-click").forEach(video => {

            video.addEventListener("click", function (e) {

                e.stopPropagation();

                const url = this.getAttribute("data-url");

                if (url) {
                    window.location.href = url;
                }

            });

        });
    </script>
}