@model ApartmentBookingSystem.ViewModels.BookingAdminViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer
@{
    ViewData["Title"] = "Admin Dashboard";

    string currentStatus = ViewBag.CurrentStatus as string ?? "";
    string currentSearch = ViewBag.CurrentSearch as string ?? "";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;

    int pendingCount = ViewBag.PendingCount ?? 0;
    int approvedCount = ViewBag.ApprovedCount ?? 0;
    int rejectedCount = ViewBag.RejectedCount ?? 0;
}

<style>
    body {
        background: linear-gradient(180deg, #fffaf3 0%, #f7fcff 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .admin-page {
        padding: 35px 0 50px;
    }

    .admin-title {
        font-size: 2.3rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .admin-subtitle {
        color: #6b7280;
        margin-bottom: 28px;
    }

    .message-box {
        background: #dcfce7;
        color: #166534;
        padding: 14px 18px;
        border-radius: 16px;
        margin-bottom: 20px;
        font-weight: 700;
    }

    .toolbar-card {
        background: #fff;
        border-radius: 24px;
        padding: 18px;
        box-shadow: 0 14px 35px rgba(0,0,0,0.08);
        margin-bottom: 24px;
    }

    .toolbar-form {
        display: grid;
        grid-template-columns: 1.4fr 1fr auto;
        gap: 14px;
        align-items: center;
    }

    .form-control,
    .form-select {
        border-radius: 14px;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #29b6f6;
            box-shadow: 0 0 0 0.2rem rgba(41, 182, 246, 0.15);
        }

    .search-btn {
        border: none;
        padding: 12px 20px;
        border-radius: 14px;
        font-weight: 700;
        color: white;
        background: linear-gradient(135deg, #29b6f6, #26c6da);
        box-shadow: 0 10px 20px rgba(41, 182, 246, 0.24);
        transition: 0.3s ease;
    }

        .search-btn:hover {
            transform: translateY(-2px);
        }

    .filters-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
    }

    .filter-chip {
        padding: 10px 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        background: #f3f4f6;
        color: #374151;
        transition: 0.3s ease;
    }

        .filter-chip:hover {
            color: #111827;
            transform: translateY(-2px);
        }

        .filter-chip.active {
            background: linear-gradient(135deg, #29b6f6, #26c6da);
            color: white;
        }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 18px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: #fff;
        border-radius: 24px;
        padding: 22px;
        box-shadow: 0 14px 35px rgba(0,0,0,0.08);
    }

    .stat-label {
        color: #6b7280;
        font-size: 0.95rem;
        margin-bottom: 8px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #111827;
    }

    .section-card {
        background: #fff;
        border-radius: 28px;
        padding: 24px;
        box-shadow: 0 16px 40px rgba(0,0,0,0.08);
        margin-bottom: 28px;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 800;
        margin-bottom: 18px;
        color: #1f2937;
    }

    .booking-card {
        border: 1px solid #eef2f7;
        border-radius: 22px;
        padding: 18px;
        margin-bottom: 16px;
        background: linear-gradient(135deg, #fcfdff, #fffaf4);
        transition: 0.3s ease;
    }

        .booking-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 26px rgba(0,0,0,0.06);
        }

    .booking-grid {
        display: grid;
        grid-template-columns: 170px 1fr;
        gap: 18px;
        align-items: start;
    }

    .booking-image img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 18px;
    }

    .booking-title {
        font-size: 1.2rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 8px;
    }

    .booking-meta {
        color: #4b5563;
        margin-bottom: 6px;
        line-height: 1.7;
    }

    .badge-custom {
        display: inline-block;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
        margin-right: 8px;
        margin-bottom: 10px;
    }

    .badge-pending {
        background: #fef3c7;
        color: #b45309;
    }

    .badge-approved {
        background: #dcfce7;
        color: #166534;
    }

    .badge-rejected {
        background: #fee2e2;
        color: #b91c1c;
    }

    .proof-link {
        display: inline-block;
        text-decoration: none;
        background: #eef6ff;
        color: #2563eb;
        padding: 10px 14px;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 10px;
        transition: 0.3s ease;
    }

        .proof-link:hover {
            color: #1d4ed8;
            transform: translateY(-2px);
        }

    .admin-action-panel {
        margin-top: 18px;
        background: #ffffff;
        border: 1px solid #edf2f7;
        border-radius: 18px;
        padding: 16px;
    }

    .panel-title {
        font-size: 1rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }

    .action-layout {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        align-items: start;
    }

    .approve-form {
        margin: 0;
    }

    .approve-btn,
    .reject-btn {
        border: none;
        border-radius: 14px;
        padding: 11px 18px;
        font-weight: 700;
        color: white;
        transition: 0.3s ease;
    }

    .approve-btn {
        background: linear-gradient(135deg, #22c55e, #16a34a);
        min-width: 120px;
    }

    .reject-btn {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        width: 100%;
    }

        .approve-btn:hover,
        .reject-btn:hover {
            transform: translateY(-2px);
        }

    .reject-form {
        margin: 0;
    }

    .note-label {
        display: block;
        font-weight: 700;
        color: #374151;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .admin-note-box {
        border-radius: 14px;
        border: 1px solid #dbe3ec;
        padding: 12px 14px;
        min-height: 95px;
        resize: vertical;
        width: 100%;
        margin-bottom: 10px;
    }

        .admin-note-box:focus {
            outline: none;
            border-color: #ef4444;
            box-shadow: 0 0 0 0.2rem rgba(239, 68, 68, 0.12);
        }

    .rejected-note {
        margin-top: 12px;
        background: #fff1f2;
        border: 1px solid #ffe4e6;
        color: #9f1239;
        padding: 12px 14px;
        border-radius: 14px;
    }

        .rejected-note strong {
            color: #881337;
        }

    .empty-box {
        background: #f9fafb;
        border-radius: 18px;
        padding: 20px;
        color: #6b7280;
        text-align: center;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .toolbar-form {
            grid-template-columns: 1fr;
        }

        .booking-grid {
            grid-template-columns: 1fr;
        }

        .booking-image img {
            height: 220px;
        }

        .action-layout {
            grid-template-columns: 1fr;
        }

        .approve-btn {
            width: 100%;
        }
    }

    .proof-link {
        display: inline-block;
        text-decoration: none;
        background: #eef6ff;
        color: #2563eb;
        padding: 10px 14px;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 10px;
        transition: 0.3s ease;
        border: none;
        cursor: pointer;
    }

        .proof-link:hover {
            color: #1d4ed8;
            transform: translateY(-2px);
        }

    .proof-modal {
        position: fixed;
        inset: 0;
        background: rgba(17, 24, 39, 0.65);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        padding: 20px;
    }

        .proof-modal.show {
            display: flex;
        }

    .proof-modal-content {
        background: white;
        border-radius: 24px;
        max-width: 900px;
        width: 100%;
        padding: 18px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        position: relative;
        animation: modalFade 0.25s ease;
    }

    .proof-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }

    .proof-modal-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #111827;
    }

    .proof-modal-close {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: #f3f4f6;
        font-size: 1.3rem;
        cursor: pointer;
        transition: 0.3s ease;
    }

        .proof-modal-close:hover {
            background: #e5e7eb;
            transform: scale(1.05);
        }

    .proof-modal-body {
        text-align: center;
    }

        .proof-modal-body img {
            max-width: 100%;
            max-height: 75vh;
            border-radius: 18px;
            object-fit: contain;
        }

    @@keyframes modalFade {
        from {
            opacity: 0;
            transform: scale(0.96);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .pagination-wrapper {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 28px;
    }

    .page-link-custom {
        min-width: 42px;
        height: 42px;
        border-radius: 12px;
        background: white;
        color: #374151;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        transition: 0.3s ease;
    }

        .page-link-custom:hover {
            transform: translateY(-2px);
            color: #111827;
        }

        .page-link-custom.active {
            background: linear-gradient(135deg, #29b6f6, #26c6da);
            color: white;
        }
</style>



<div class="container admin-page">
    <h2 class="admin-title">@Localizer["PageTitle"]</h2>
    <p class="admin-subtitle">@Localizer["PageSubtitle"]</p>

    @if (TempData["AdminMessage"] != null)
    {
        <div class="message-box">
            @TempData["AdminMessage"]
        </div>
    }

    <div class="toolbar-card">
        <form method="get" asp-action="AdminDashboard" class="toolbar-form">
            <input type="text"
                   name="search"
                   value="@currentSearch"
                   class="form-control"
                   placeholder="@Localizer["SearchPlaceholder"]" />

            <select name="status" class="form-select">
                <option value="">@Localizer["AllStatuses"]</option>
                <option value="pending" selected="@(currentStatus == "pending")">@Localizer["Pending"]</option>
                <option value="approved" selected="@(currentStatus == "approved")">@Localizer["Approved"]</option>
                <option value="rejected" selected="@(currentStatus == "rejected")">@Localizer["Rejected"]</option>
            </select>

            <button type="submit" class="search-btn">@Localizer["Search"]</button>
        </form>

        <div class="filters-row">
            <a asp-action="AdminDashboard"
               asp-route-search="@currentSearch"
               class="filter-chip @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
                @Localizer["All"]
            </a>

            <a asp-action="AdminDashboard"
               asp-route-status="pending"
               asp-route-search="@currentSearch"
               class="filter-chip @(currentStatus == "pending" ? "active" : "")">
                @Localizer["Pending"]
            </a>

            <a asp-action="AdminDashboard"
               asp-route-status="approved"
               asp-route-search="@currentSearch"
               class="filter-chip @(currentStatus == "approved" ? "active" : "")">
                @Localizer["Approved"]
            </a>

            <a asp-action="AdminDashboard"
               asp-route-status="rejected"
               asp-route-search="@currentSearch"
               class="filter-chip @(currentStatus == "rejected" ? "active" : "")">
                @Localizer["Rejected"]
            </a>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-label">@Localizer["PendingBookings"]</div>
            <div class="stat-value">@pendingCount</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">@Localizer["ApprovedBookings"]</div>
            <div class="stat-value">@approvedCount</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">@Localizer["RejectedBookings"]</div>
            <div class="stat-value">@rejectedCount</div>
        </div>
    </div>

    <div class="section-card">
        <div class="section-title">@Localizer["PendingReview"]</div>

        @if (Model.PendingBookings.Any())
        {
            @foreach (var booking in Model.PendingBookings)
            {
                var imageUrl = booking.Apartment?.Images != null && booking.Apartment.Images.Any()
                ? booking.Apartment.Images.First().ImageUrl
                : "/images/no-image.png";

                <div class="booking-card">
                    <div class="booking-grid">
                        <div class="booking-image">
                            <img src="@imageUrl" alt="@booking.Apartment?.Title" />
                        </div>

                        <div>
                            <div class="booking-title">@booking.Apartment?.Title</div>

                            <span class="badge-custom badge-pending">@Localizer["Pending"]</span>

                            <div class="booking-meta"><strong>@Localizer["User"]:</strong> @booking.User?.FullName (@booking.User?.Email)</div>
                            <div class="booking-meta"><strong>@Localizer["PhoneNumber"]:</strong> @booking.User?.PhoneNumber</div>
                            <div class="booking-meta"><strong>@Localizer["NationalId"]:</strong> @booking.User?.NationalId</div>
                            <div class="booking-meta"><strong>@Localizer["Apartment"]:</strong> @booking.Apartment?.City - @booking.Apartment?.Area</div>
                            <div class="booking-meta"><strong>@Localizer["CheckIn"]:</strong> @booking.CheckInDate.ToString("yyyy-MM-dd")</div>
                            <div class="booking-meta"><strong>@Localizer["CheckOut"]:</strong> @booking.CheckOutDate.ToString("yyyy-MM-dd")</div>
                            <div class="booking-meta"><strong>@Localizer["TotalPrice"]:</strong> @booking.TotalPrice @Localizer["CurrencyEGP"]</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentMethod"]:</strong> @booking.PaymentMethod</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentStatus"]:</strong> @booking.PaymentStatus</div>
                            <div class="booking-meta"><strong>@Localizer["CreatedAt"]:</strong> @booking.CreatedAt.ToString("yyyy-MM-dd hh:mm tt")</div>

                            @if (!string.IsNullOrEmpty(booking.PaymentProofImageUrl))
                            {
                                <button type="button"
                                        class="proof-link proof-btn-trigger"
                                        data-image="@booking.PaymentProofImageUrl">
                                    @Localizer["ViewPaymentProof"]
                                </button>
                            }

                            <div class="admin-action-panel">
                                <div class="panel-title">@Localizer["AdminActions"]</div>

                                <div class="action-layout">
                                    <form asp-action="Approve" method="post" class="approve-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.Id" />
                                        <button type="submit" class="approve-btn">@Localizer["Approve"]</button>
                                    </form>

                                    <form asp-action="Reject" method="post" class="reject-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.Id" />

                                        <label class="note-label">@Localizer["RejectWithNote"]</label>
                                        <textarea name="adminNotes"
                                          class="admin-note-box"
                                          placeholder="@Localizer["RejectReasonPlaceholder"]"
                                          required></textarea>

                                        <button type="submit" class="reject-btn">@Localizer["RejectBooking"]</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-box">@Localizer["NoPendingBookings"]</div>
        }
    </div>

    <div class="section-card">
        <div class="section-title">@Localizer["ApprovedBookings"]</div>

        @if (Model.ApprovedBookings.Any())
        {
            @foreach (var booking in Model.ApprovedBookings)
            {
                var imageUrl = booking.Apartment?.Images != null && booking.Apartment.Images.Any()
                ? booking.Apartment.Images.First().ImageUrl
                : "/images/no-image.png";

                <div class="booking-card">
                    <div class="booking-grid">
                        <div class="booking-image">
                            <img src="@imageUrl" alt="@booking.Apartment?.Title" />
                        </div>

                        <div>
                            <div class="booking-title">@booking.Apartment?.Title</div>
                            <span class="badge-custom badge-approved">@Localizer["Approved"]</span>

                            <div class="booking-meta"><strong>@Localizer["User"]:</strong> @booking.User?.FullName (@booking.User?.Email)</div>
                            <div class="booking-meta"><strong>@Localizer["PhoneNumber"]:</strong> @booking.User?.PhoneNumber</div>
                            <div class="booking-meta"><strong>@Localizer["NationalId"]:</strong> @booking.User?.NationalId</div>
                            <div class="booking-meta"><strong>@Localizer["Apartment"]:</strong> @booking.Apartment?.City - @booking.Apartment?.Area</div>
                            <div class="booking-meta"><strong>@Localizer["Dates"]:</strong> @booking.CheckInDate.ToString("yyyy-MM-dd") → @booking.CheckOutDate.ToString("yyyy-MM-dd")</div>
                            <div class="booking-meta"><strong>@Localizer["Total"]:</strong> @booking.TotalPrice @Localizer["CurrencyEGP"]</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentMethod"]:</strong> @booking.PaymentMethod</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentStatus"]:</strong> @booking.PaymentStatus</div>

                            @if (!string.IsNullOrEmpty(booking.PaymentProofImageUrl))
                            {
                                <button type="button"
                                        class="proof-link proof-btn-trigger"
                                        data-image="@booking.PaymentProofImageUrl">
                                    @Localizer["ViewPaymentProof"]
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-box">@Localizer["NoApprovedBookings"]</div>
        }
    </div>

    <div class="section-card">
        <div class="section-title">@Localizer["RejectedBookings"]</div>

        @if (Model.RejectedBookings.Any())
        {
            @foreach (var booking in Model.RejectedBookings)
            {
                var imageUrl = booking.Apartment?.Images != null && booking.Apartment.Images.Any()
                ? booking.Apartment.Images.First().ImageUrl
                : "/images/no-image.png";

                <div class="booking-card">
                    <div class="booking-grid">
                        <div class="booking-image">
                            <img src="@imageUrl" alt="@booking.Apartment?.Title" />
                        </div>

                        <div>
                            <div class="booking-title">@booking.Apartment?.Title</div>
                            <span class="badge-custom badge-rejected">@Localizer["Rejected"]</span>

                            <div class="booking-meta"><strong>@Localizer["User"]:</strong> @booking.User?.FullName (@booking.User?.Email)</div>
                            <div class="booking-meta"><strong>@Localizer["Dates"]:</strong> @booking.CheckInDate.ToString("yyyy-MM-dd") → @booking.CheckOutDate.ToString("yyyy-MM-dd")</div>
                            <div class="booking-meta"><strong>@Localizer["Total"]:</strong> @booking.TotalPrice @Localizer["CurrencyEGP"]</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentMethod"]:</strong> @booking.PaymentMethod</div>
                            <div class="booking-meta"><strong>@Localizer["PaymentStatus"]:</strong> @booking.PaymentStatus</div>

                            @if (!string.IsNullOrEmpty(booking.PaymentProofImageUrl))
                            {
                                <button type="button"
                                        class="proof-link proof-btn-trigger"
                                        data-image="@booking.PaymentProofImageUrl">
                                    @Localizer["ViewPaymentProof"]
                                </button>
                            }

                            @if (!string.IsNullOrEmpty(booking.AdminNotes))
                            {
                                <div class="rejected-note">
                                    <strong>@Localizer["AdminNote"]:</strong> @booking.AdminNotes
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-box">@Localizer["NoRejectedBookings"]</div>
        }
    </div>

    <div class="proof-modal" id="proofModal">
        <div class="proof-modal-content">
            <div class="proof-modal-header">
                <div class="proof-modal-title">@Localizer["PaymentProofPreview"]</div>
                <button type="button" class="proof-modal-close" id="closeProofModal">&times;</button>
            </div>

            <div class="proof-modal-body">
                <img id="proofModalImage" src="" alt="@Localizer["PaymentProofPreview"]" />
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <div class="pagination-wrapper">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a asp-action="AdminDashboard"
                   asp-route-page="@i"
                   asp-route-status="@currentStatus"
                   asp-route-search="@currentSearch"
                   class="page-link-custom @(i == currentPage ? "active" : "")">
                    @i
                </a>
            }
        </div>
    }
</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modal = document.getElementById("proofModal");
            const modalImage = document.getElementById("proofModalImage");
            const closeBtn = document.getElementById("closeProofModal");
            const triggers = document.querySelectorAll(".proof-btn-trigger");

            triggers.forEach(btn => {
                btn.addEventListener("click", function () {
                    const imageUrl = this.getAttribute("data-image");
                    modalImage.src = imageUrl;
                    modal.classList.add("show");
                });
            });

            closeBtn.addEventListener("click", function () {
                modal.classList.remove("show");
                modalImage.src = "";
            });

            modal.addEventListener("click", function (e) {
                if (e.target === modal) {
                    modal.classList.remove("show");
                    modalImage.src = "";
                }
            });

            document.addEventListener("keydown", function (e) {
                if (e.key === "Escape") {
                    modal.classList.remove("show");
                    modalImage.src = "";
                }
            });
        });
    </script>
}