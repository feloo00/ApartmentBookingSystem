@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}
<style>

    body {
        background: linear-gradient(180deg,#fffaf3 0%,#f7fcff 100%);
        font-family: 'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
    }

    .register-page {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 0;
    }

    .register-card {
        background: white;
        border-radius: 28px;
        padding: 40px;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    }

    .register-title {
        font-size: 2rem;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .register-subtitle {
        color: #6b7280;
        margin-bottom: 28px;
    }

    .form-control {
        border-radius: 14px;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
    }

        .form-control:focus {
            border-color: #29b6f6;
            box-shadow: 0 0 0 0.2rem rgba(41,182,246,0.15);
        }

    .form-floating {
        margin-bottom: 18px;
    }

    .register-btn {
        width: 100%;
        border: none;
        border-radius: 16px;
        padding: 14px;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg,#29b6f6,#26c6da);
        box-shadow: 0 12px 24px rgba(41,182,246,0.25);
        transition: 0.3s;
    }

        .register-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 30px rgba(41,182,246,0.35);
        }

    .login-link {
        text-align: center;
        margin-top: 20px;
        color: #6b7280;
    }

        .login-link a {
            color: #29b6f6;
            font-weight: 700;
            text-decoration: none;
        }

            .login-link a:hover {
                text-decoration: underline;
            }

</style>

<div class="register-page">

    <div class="register-card">

        <div class="register-title">Create Account</div>
        <div class="register-subtitle">
            Register to start booking apartments.
        </div>

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating">
                <input asp-for="Input.FullName" class="form-control" placeholder="Full Name" />
                <label asp-for="Input.FullName"></label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="form-floating">
                <input asp-for="Input.Email" class="form-control" placeholder="Email" autocomplete="email" />
                <label asp-for="Input.Email"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+201234567890" autocomplete="tel" />
                <label asp-for="Input.PhoneNumber"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-floating">
                <input asp-for="Input.NationalId" class="form-control" placeholder="National ID" inputmode="numeric" />
                <label asp-for="Input.NationalId"></label>
                <span asp-validation-for="Input.NationalId" class="text-danger"></span>
            </div>

            <div class="form-floating">
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                <label asp-for="Input.Password"></label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-floating">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                <label asp-for="Input.ConfirmPassword"></label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="register-btn">
                Create Account
            </button>

        </form>

        <div class="login-link">
            Already have an account?
            <a asp-page="./Login">Login</a>
        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
